// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ========================
// AUTH / USER
// ========================

model User {
  id            String     @id @default(cuid())
  name          String?
  email         String?    @unique
  emailVerified DateTime?
  image         String?
  password      String?

  role          UserRole   @default(VOLUNTEER)
  status        UserStatus @default(ACTIVE)
  onboarded     Boolean    @default(false)

  // Volunteer profile
  bio           String?   @db.Text
  location      String?
  postcode      String?
  lat           Float?
  lon           Float?
  skills        UserSkill[]
  interests     UserCategory[]
  availability  String?   // JSON string: ["monday", "weekend", ...]
  maxDistance   Int?      @default(25) // km

  birthYear           Int?      // geboortejaar (bijv. 1985)

  motivationProfile   String?   @db.Text   // JSON: {waarden,begrip,sociaal,loopbaan,bescherming,verbetering}
  schwartzProfile     String?   @db.Text   // JSON: {zorg,universalisme,zelfrichting,stimulatie,hedonisme,prestatie,macht,veiligheid,conformiteit,traditie}
  streakDays          Int       @default(0)
  lastActiveDate      DateTime?

  openToInvitations Boolean   @default(true)
  commitmentType    String?   // "wekelijks" | "projectmatig" | "incidenteel" | "alles"

  // Internal admin notes (not visible to user)
  adminNotes        String?   @db.Text

  // Gemeente admin link
  gemeenteSlug      String?   // set when role = GEMEENTE_ADMIN

  // Password reset
  resetToken        String?   @unique
  resetTokenExpiry  DateTime?

  // Organisation link
  organisation  Organisation? @relation("OrgAdmin")
  organisationId String?

  // Relations
  swipesGiven           Swipe[]          @relation("SwipeFrom")
  matchesAsVol          Match[]          @relation("MatchVolunteer")
  conversations         ConversationParticipant[]
  sentMessages          Message[]        @relation("MessageSender")
  adminLogs             AdminLog[]       @relation("AdminActions")
  receivedInvitations   Invitation[]     @relation("ReceivedInvitations")
  activityRegistrations ActivityRegistration[] @relation("ActivityRegistrations")

  // Notifications
  notifications Notification[]

  // NextAuth
  accounts      Account[]
  sessions      Session[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("users")
}

enum UserRole {
  VOLUNTEER
  ORGANISATION
  ADMIN
  GEMEENTE_ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ========================
// ORGANISATION
// ========================

model Organisation {
  id              String    @id @default(cuid())
  name            String
  slug            String    @unique
  description     String?   @db.Text
  logo            String?
  website         String?
  email           String?
  phone           String?
  address         String?
  city            String?

  status          OrgStatus @default(PENDING_APPROVAL)
  verifiedAt      DateTime?
  rejectionReason String?   @db.Text

  postcode    String?
  lat         Float?
  lon         Float?

  adminId     String   @unique
  admin       User     @relation("OrgAdmin", fields: [adminId], references: [id])

  vacancies        Vacancy[]
  activities       GroupActivity[]
  categories       OrgCategory[]
  sentInvitations  Invitation[]
  handprint        OrgHandprint?

  orgSize           String?   // "starter" | "middel" | "groot"
  inzetType         String?   @db.Text  // JSON: ["wekelijks","projectmatig",...]
  volunteerBenefits String?   @db.Text  // JSON: ["begeleiding","reiskosten",...]

  avgResponseHours   Float?
  slaScore           Int     @default(100)

  // Internal admin notes (not visible to organisation)
  adminNotes  String?   @db.Text

  // Multi-tenant: optional link to a municipality (gemeente)
  gemeenteId  String?
  gemeente    Gemeente? @relation(fields: [gemeenteId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("organisations")
}

enum OrgStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
  SUSPENDED
}

// ========================
// VACANCY
// ========================

model Vacancy {
  id             String        @id @default(cuid())
  title          String
  description    String        @db.Text
  imageUrl       String?
  location       String?
  city           String?
  postcode       String?
  lat            Float?
  lon            Float?
  remote         Boolean       @default(false)
  hours          Int?          // hours per week
  duration       String?       // "3 months", "ongoing", etc.
  status         VacancyStatus @default(ACTIVE)

  organisationId String
  organisation   Organisation  @relation(fields: [organisationId], references: [id], onDelete: Cascade)

  skills         VacancySkill[]
  categories     VacancyCategory[]
  swipes         Swipe[]
  matches        Match[]
  invitations    Invitation[]

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@map("vacancies")
}

enum VacancyStatus {
  DRAFT
  ACTIVE
  PAUSED
  CLOSED
}

// ========================
// CATEGORIES & SKILLS
// ========================

model Category {
  id            String         @id @default(cuid())
  name          String         @unique
  icon          String?
  color         String?

  userInterests      UserCategory[]
  orgCategories      OrgCategory[]
  vacancyCategories  VacancyCategory[]
  activityCategories ActivityCategory[]

  @@map("categories")
}

model Skill {
  id           String        @id @default(cuid())
  name         String        @unique

  userSkills     UserSkill[]
  vacancySkills  VacancySkill[]
  activitySkills ActivitySkill[]

  @@map("skills")
}

model UserSkill {
  userId  String
  skillId String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill   Skill  @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([userId, skillId])
  @@map("user_skills")
}

model UserCategory {
  userId     String
  categoryId String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([userId, categoryId])
  @@map("user_categories")
}

model OrgCategory {
  organisationId String
  categoryId     String
  organisation   Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  category       Category     @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([organisationId, categoryId])
  @@map("org_categories")
}

model VacancySkill {
  vacancyId String
  skillId   String
  vacancy   Vacancy @relation(fields: [vacancyId], references: [id], onDelete: Cascade)
  skill     Skill   @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([vacancyId, skillId])
  @@map("vacancy_skills")
}

model VacancyCategory {
  vacancyId  String
  categoryId String
  vacancy    Vacancy  @relation(fields: [vacancyId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([vacancyId, categoryId])
  @@map("vacancy_categories")
}

// ========================
// SWIPE & MATCH
// ========================

model Swipe {
  id        String    @id @default(cuid())
  direction SwipeDir

  fromId    String
  from      User      @relation("SwipeFrom", fields: [fromId], references: [id], onDelete: Cascade)

  vacancyId String
  vacancy   Vacancy   @relation(fields: [vacancyId], references: [id], onDelete: Cascade)

  matchReason   String?   // "Goede zaak"|"Past bij mijn skills"|"Flexibele tijden"|"Dichtbij mij"
  scoreSnapshot String?  @db.Text  // JSON: MatchScore at swipe time (for RL analytics)

  createdAt DateTime  @default(now())

  @@unique([fromId, vacancyId])
  @@map("swipes")
}

enum SwipeDir {
  LIKE
  DISLIKE
  SUPER_LIKE
}

model Match {
  id             String      @id @default(cuid())
  status         MatchStatus @default(PENDING)

  volunteerId    String
  volunteer      User        @relation("MatchVolunteer", fields: [volunteerId], references: [id], onDelete: Cascade)

  vacancyId      String
  vacancy        Vacancy     @relation(fields: [vacancyId], references: [id], onDelete: Cascade)

  conversation   Conversation?

  startedAt        DateTime?   // set on ACCEPTED (for SLA measurement)
  confirmedAt      DateTime?   // set on CONFIRMED (vrijwilliger actief — check-ins starten hier)
  checkIn1SentAt   DateTime?   // week 1 (7d after confirmedAt)
  checkIn4SentAt   DateTime?   // week 4 (28d after confirmedAt)
  checkIn12SentAt  DateTime?   // week 12 (84d after confirmedAt)
  reminder14SentAt DateTime?   // reminder to org after 14d ACCEPTED without CONFIRMED
  reminder28SentAt DateTime?   // reminder to org after 28d ACCEPTED without CONFIRMED

  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@unique([volunteerId, vacancyId])
  @@map("matches")
}

enum MatchStatus {
  PENDING
  ACCEPTED    // org wil contact maken — chat geopend, telt NIET als plaatsing
  CONFIRMED   // org heeft bevestigd dat vrijwilliger actief is — telt als plaatsing
  REJECTED
  COMPLETED
}

// ========================
// CHAT / MESSAGING
// ========================

model Conversation {
  id           String                    @id @default(cuid())
  matchId      String?                   @unique
  match        Match?                    @relation(fields: [matchId], references: [id])

  participants ConversationParticipant[]
  messages     Message[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("conversations")
}

model ConversationParticipant {
  conversationId String
  userId         String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastReadAt     DateTime?

  @@id([conversationId, userId])
  @@map("conversation_participants")
}

model Message {
  id             String       @id @default(cuid())
  content        String       @db.Text
  type           MessageType  @default(TEXT)

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  senderId       String
  sender         User         @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("messages")
}

enum MessageType {
  TEXT
  IMAGE
  FILE
  SYSTEM
}

// ========================
// INVITATIONS
// ========================

enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
}

model Invitation {
  id             String           @id @default(cuid())
  message        String?          @db.Text
  status         InvitationStatus @default(PENDING)

  organisationId String
  organisation   Organisation     @relation(fields: [organisationId], references: [id], onDelete: Cascade)

  vacancyId      String
  vacancy        Vacancy          @relation(fields: [vacancyId], references: [id], onDelete: Cascade)

  volunteerId    String
  volunteer      User             @relation("ReceivedInvitations", fields: [volunteerId], references: [id], onDelete: Cascade)

  conversationId String?          // set on ACCEPTED

  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@unique([organisationId, vacancyId, volunteerId])
  @@map("invitations")
}

// ========================
// MULTI-TENANT / GEMEENTEN
// ========================

model Gemeente {
  id           String         @id @default(cuid())
  slug         String         @unique   // "heemstede", "amsterdam"
  name         String                   // "WijHeemstede" (platform-branded name shown in UI)
  displayName  String                   // "Heemstede"  (official municipality name)
  logoUrl      String?                  // "/images/gemeenten/heemstede-logo.svg"
  primaryColor String         @default("#7c3aed")
  tagline      String?                  // "Vrijwilligerswerk in Heemstede & omgeving"
  website      String?
  contactEmail String?

  // ── Extended branding ─────────────────────────────────────────
  accentColor    String?                // lighter accent for gradients/hover
  heroImageUrl   String?                // background image on homepage/swipe
  welcomeTitle   String?                // "Welkom bij WijHeemstede"
  welcomeMessage String?   @db.Text    // onboarding welcome body text
  contactPhone   String?                // "023-547 8900"
  contactAddress String?   @db.Text    // street + city
  socialLinks    Json?                  // { facebook?, instagram?, linkedin?, twitter? }
  emailSignature String?   @db.Text    // appended to system emails
  faviconUrl     String?                // custom favicon URL

  organisations Organisation[]
  activities    GroupActivity[]
  dashboard     GemeenteDashboard?

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("gemeenten")
}

// ========================
// ADMIN
// ========================

model AdminLog {
  id         String      @id @default(cuid())
  adminId    String
  admin      User        @relation("AdminActions", fields: [adminId], references: [id])
  action     AdminAction
  entityType String      // "Organisation" | "User" | "Vacancy"
  entityId   String
  reason     String?     @db.Text
  metadata   Json?
  createdAt  DateTime    @default(now())

  @@map("admin_logs")
}

enum AdminAction {
  APPROVE_ORG
  REJECT_ORG
  SUSPEND_ORG
  UNSUSPEND_ORG
  SUSPEND_USER
  BAN_USER
  REINSTATE_USER
}

// ========================
// PLATFORM SETTINGS
// ========================

model AppSettings {
  id        String   @id @default("default")
  data      String   @db.Text  // JSON blob
  updatedAt DateTime @updatedAt

  @@map("app_settings")
}

// ========================
// NOTIFICATIONS
// ========================

enum NotificationType {
  NEW_MATCH
  MATCH_ACCEPTED
  MATCH_REJECTED
  NEW_INVITATION
  INVITATION_ACCEPTED
  NEW_MESSAGE
  ACTIVITY_REMINDER
  ACTIVITY_CANCELLED
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String
  link      String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId, read])
  @@index([userId, createdAt(sort: Desc)])
  @@map("notifications")
}

// ========================
// GROEPSACTIVITEITEN
// ========================

enum ActivityType {
  BIJEENKOMST      // Algemene bijeenkomst
  WORKSHOP         // Praktische workshop
  CURSUS           // Meerdaagse training/cursus
  EVENEMENT        // Eenmalig evenement
  INLOOPSPREEKUUR  // Open inloop
}

enum ActivityStatus {
  DRAFT
  PUBLISHED
  CANCELLED
  COMPLETED
}

enum RegistrationStatus {
  REGISTERED    // Aangemeld
  WAITLISTED    // Wachtlijst (vol)
  ATTENDED      // Aanwezig geweest
  ABSENT        // No-show
  CANCELLED     // Zelf afgemeld
}

model GroupActivity {
  id          String         @id @default(cuid())
  title       String
  description String         @db.Text
  imageUrl    String?
  type        ActivityType   @default(BIJEENKOMST)
  status      ActivityStatus @default(DRAFT)

  // Wanneer
  startDateTime DateTime
  endDateTime   DateTime

  // Waar
  online   Boolean @default(false)
  meetUrl  String?           // Zoom/Teams bij online
  location String?           // "Dorpshuis De Wiel"
  address  String?
  city     String?
  postcode String?
  lat      Float?
  lon      Float?

  // Capaciteit
  maxCapacity     Int?     // null = onbeperkt
  waitlistEnabled Boolean  @default(true)

  // Uniek token voor QR self-check-in
  qrToken String @unique @default(cuid())

  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)

  gemeenteId String?
  gemeente   Gemeente? @relation(fields: [gemeenteId], references: [id])

  categories    ActivityCategory[]
  skills        ActivitySkill[]
  registrations ActivityRegistration[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("group_activities")
}

model ActivityRegistration {
  id         String             @id @default(cuid())
  activityId String
  activity   GroupActivity      @relation(fields: [activityId], references: [id], onDelete: Cascade)
  volunteerId String
  volunteer  User               @relation("ActivityRegistrations", fields: [volunteerId], references: [id], onDelete: Cascade)
  status     RegistrationStatus @default(REGISTERED)

  registeredAt      DateTime  @default(now())
  cancelledAt       DateTime?
  checkedInAt       DateTime? // tijdstip QR of handmatig check-in
  reminder24hSentAt DateTime? // reminder email dag van tevoren

  feedback String? @db.Text // post-activiteit feedback
  rating   Int?              // 1–5 sterren

  @@unique([activityId, volunteerId])
  @@map("activity_registrations")
}

model ActivityCategory {
  activityId String
  categoryId String
  activity   GroupActivity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  category   Category      @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([activityId, categoryId])
  @@map("activity_categories")
}

model ActivitySkill {
  activityId String
  skillId    String
  activity   GroupActivity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  skill      Skill         @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([activityId, skillId])
  @@map("activity_skills")
}

// ========================
// IMPACT / HANDPRINT
// ========================

model OrgHandprint {
  id                     String       @id @default(cuid())
  organisationId         String       @unique
  organisation           Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)

  // Uurwaarde berekening
  totaalUrenJaarlijks    Int          @default(0)
  maatschappelijkeWaarde Float        @default(0)   // vervangingswaarde in euro's
  sroiWaarde             Float        @default(0)   // SROI in euro's (4,2× multiplier)

  // Retentie
  retentieScore          Float        @default(0)   // 0-100
  aantalActieveMatches   Int          @default(0)
  aantalAfgerondMatches  Int          @default(0)
  gemLooptijdMaanden     Float        @default(0)

  // SDG scores (JSON map: { "3": 0.9, "10": 0.7, ... })
  sdgScores              Json?

  // Motivatieprofiel (VFI dimensies geaggregeerd)
  dominantMotivatie      String?
  motivatieDistributie   Json?

  // Meta
  isPubliek              Boolean      @default(true)
  laasteBerekening       DateTime     @default(now())
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt

  @@map("org_handprints")
}

model GemeenteDashboard {
  id                  String   @id @default(cuid())
  gemeenteId          String   @unique
  gemeente            Gemeente @relation(fields: [gemeenteId], references: [id], onDelete: Cascade)

  abonnementType      String   @default("basis")   // "basis" | "pro" | "enterprise"

  // Gecachte aggregates (herberekend via nachtelijke cron)
  totaalVrijwilligers Int      @default(0)
  totaalUren          Int      @default(0)
  totaalWaarde        Float    @default(0)
  aantalOrganisaties  Int      @default(0)
  gemRetentieScore    Float    @default(0)
  laasteSync          DateTime @default(now())

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("gemeente_dashboards")
}
